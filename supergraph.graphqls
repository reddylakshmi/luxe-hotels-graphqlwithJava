  eventSpaces(hotelId: ID!, filter: EventSpaceFilter): [EventSpace!]! @join__field(graph: MEETINGS)
  eventSpace(id: ID!): EventSpace @join__field(graph: MEETINGS)
  searchEventSpaces(input: EventSpaceSearchInput!): EventSpaceSearchResult! @join__field(graph: MEETINGS)
  cateringMenus(hotelId: ID!): [CateringMenu!]! @join__field(graph: MEETINGS)
  rfp(id: ID!): RFP @join__field(graph: MEETINGS)
  myRFPs(status: RFPStatus, first: Int, after: String): RFPConnection! @join__field(graph: MEETINGS)
  groupBlock(id: ID!): GroupBlock @join__field(graph: MEETINGS)
  myNotifications(first: Int, after: String, filter: NotificationFilter): NotificationConnection! @join__field(graph: NOTIFICATIONS)
  notification(id: ID!): Notification @join__field(graph: NOTIFICATIONS)
  unreadCount: Int! @join__field(graph: NOTIFICATIONS)
  notificationPreferences: NotificationPreferences! @join__field(graph: NOTIFICATIONS)
  myMessageThreads(first: Int, status: ThreadStatus): [MessageThread!]! @join__field(graph: NOTIFICATIONS)
  messageThread(id: ID!): MessageThread @join__field(graph: NOTIFICATIONS)
  myDevices: [PushDevice!]! @join__field(graph: NOTIFICATIONS)
  searchRates(input: SearchRatesInput!): SearchRatesResult! @join__field(graph: PRICING)
  validateRate(rateToken: String!): ValidateRateResult! @join__field(graph: PRICING)
  ratePlan(id: ID!): RatePlan @join__field(graph: PRICING)
  promotions(first: Int, after: String, brandIds: [ID!], memberOnly: Boolean): [Promotion!]! @join__field(graph: PRICING)
  promotion(code: String!): Promotion @join__field(graph: PRICING)
  package(id: ID!): Package @join__field(graph: PRICING)
  rateCalendar(input: RateCalendarInput!): [DateRateSummary!]! @join__field(graph: PRICING)
  giftCardBalance(code: String!): GiftCardBalance @join__field(graph: PRICING)
  redemptionRates(input: RedemptionInput!): [RedemptionRate!]! @join__field(graph: PRICING)
  hotel(id: ID!): Hotel @join__field(graph: PROPERTY)
  hotelBySlug(slug: String!): Hotel @join__field(graph: PROPERTY)
  hotels(first: Int = 10, after: String, filter: HotelFilter, sortBy: HotelSortField): HotelConnection! @join__field(graph: PROPERTY)

  """
  Counts of hotels matching the given filter, broken out by each filterable
  dimension. Used by the search-results filter UI to show "Maison Lumière (1)"
  next to every option, scoped to the current search (city/destination/etc.).
  """
  hotelFacets(filter: HotelFilter): HotelFacets! @join__field(graph: PROPERTY)
  brand(id: ID!): Brand @join__field(graph: PROPERTY)
  brandByCode(code: String!): Brand @join__field(graph: PROPERTY)
  brands(first: Int = 20, after: String, tier: BrandTier): BrandConnection! @join__field(graph: PROPERTY)
  roomType(id: ID!): RoomType @join__field(graph: PROPERTY)
  featuredHotels(first: Int = 6, brandTier: BrandTier, countryCode: CountryCode): [Hotel!]! @join__field(graph: PROPERTY)

  """
  Lightweight typeahead query — returns up to {@code limit} suggestions matching
  the partial query against hotel names, city names, and country names.
  Optimised for the destination-search input on the home / search-results page;
  prefer this over the full {@code hotels(filter: { query })} query when only
  a "what could the user mean?" preview list is needed.
  """
  destinationSuggestions(query: String!, limit: Int = 10): [DestinationSuggestion!]! @join__field(graph: PROPERTY)
  restaurant(id: ID!): Restaurant @join__field(graph: PROPERTY)
  spa(id: ID!): Spa @join__field(graph: PROPERTY)
  reservation(id: ID!): Reservation @join__field(graph: RESERVATIONS)
  reservationByConfirmationNumber(confirmationNumber: String!, guestLastName: String): Reservation @join__field(graph: RESERVATIONS)
  myReservations(first: Int, after: String, filter: ReservationFilter, sortBy: ReservationSortField): ReservationConnection! @join__field(graph: RESERVATIONS)
  checkInEligibility(reservationId: ID!): CheckInEligibility! @join__field(graph: RESERVATIONS)
  digitalKey(reservationId: ID!): DigitalKey @join__field(graph: RESERVATIONS)
  myDiningReservations(upcoming: Boolean, first: Int, after: String): [DiningReservation!]! @join__field(graph: RESERVATIONS)
  mySpaAppointments(upcoming: Boolean, first: Int, after: String): [SpaAppointment!]! @join__field(graph: RESERVATIONS)
  myTransportationBookings(upcoming: Boolean, first: Int): [TransportationBooking!]! @join__field(graph: RESERVATIONS)
}

