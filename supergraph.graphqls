  contentCollection(slug: String!, locale: String): ContentCollection @join__field(graph: CONTENT)
  myCorporateAccount: CorporateAccount @join__field(graph: CORPORATE)
  corporateAccount(id: ID!): CorporateAccount @join__field(graph: CORPORATE)
  travelReport(accountId: ID!, period: ReportingPeriod!): TravelReport! @join__field(graph: CORPORATE)
  pendingApprovals(accountId: ID): [TravelApproval!]! @join__field(graph: CORPORATE)
  travelPolicy(accountId: ID!): TravelPolicy @join__field(graph: CORPORATE)
  negotiatedRates(accountId: ID!, propertyId: ID): [NegotiatedRate!]! @join__field(graph: CORPORATE)
  experiences(hotelId: ID!, category: ExperienceCategory, date: Date): [Experience!]! @join__field(graph: EXPERIENCES)
  experience(id: ID!): Experience @join__field(graph: EXPERIENCES)
  experienceAvailability(experienceId: ID!, date: Date!, partySize: Int!): ExperienceAvailability! @join__field(graph: EXPERIENCES)
  spaTreatmentMenu(hotelId: ID!): [SpaTreatment!]! @join__field(graph: EXPERIENCES)
  restaurantAvailability(hotelId: ID!, date: Date!, partySize: Int!): RestaurantAvailability! @join__field(graph: EXPERIENCES)
  golfTeeTimeAvailability(hotelId: ID!, date: Date!, players: Int!): GolfTeeTimeAvailability! @join__field(graph: EXPERIENCES)
  myExperienceBookings(first: Int, after: String, upcoming: Boolean): ExperienceBookingConnection! @join__field(graph: EXPERIENCES)
  me: GuestProfile @join__field(graph: GUEST)
  guest(id: ID!): GuestProfile @join__field(graph: GUEST)
  guests(first: Int = 10, after: String): GuestProfileConnection! @join__field(graph: GUEST)
  myLoyaltyAccount: LoyaltyAccount @join__field(graph: LOYALTY)
  loyaltyAccount(loyaltyNumber: String!): LoyaltyAccount @join__field(graph: LOYALTY)
