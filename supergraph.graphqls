  updatePreferences(input: UpdatePreferencesInput!): GuestPreferences! @join__field(graph: GUEST)
  addAddress(input: AddAddressInput!): AddAddressResult! @join__field(graph: GUEST)
  updateAddress(id: ID!, input: UpdateAddressInput!): UpdateAddressResult! @join__field(graph: GUEST)
  removeAddress(id: ID!): Boolean! @join__field(graph: GUEST)
  setPrimaryAddress(id: ID!): GuestAddress @join__field(graph: GUEST)
  addPaymentMethod(input: AddPaymentMethodInput!): AddPaymentMethodResult! @join__field(graph: GUEST)
  removePaymentMethod(id: ID!): Boolean! @join__field(graph: GUEST)
  setDefaultPaymentMethod(id: ID!): PaymentMethod @join__field(graph: GUEST)
  saveHotel(hotelId: ID!): SavedHotel! @join__field(graph: GUEST)
  unsaveHotel(hotelId: ID!): Boolean! @join__field(graph: GUEST)
