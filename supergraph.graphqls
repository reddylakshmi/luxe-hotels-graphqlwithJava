  bookDining(input: BookDiningInput!, idempotencyKey: UUID!): BookDiningResult! @join__field(graph: EXPERIENCES)
  bookGolfTeeTime(input: BookGolfInput!, idempotencyKey: UUID!): BookGolfResult! @join__field(graph: EXPERIENCES)
  cancelExperienceBooking(bookingId: ID!, reason: String): CancelExperienceResult! @join__field(graph: EXPERIENCES)
